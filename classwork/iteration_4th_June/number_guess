import random 

secret = random.randint(1,50)
attempts = 0

while True:
    guess = int(input("Enter your guess:"))
    attempts +=1
    
    if guess > secret:
        print("Too High")
    elif guess < secret:
        print("Too Low")
    else:
        print("Correct Guess")
        break
    print("Total attempts=", attempts)
